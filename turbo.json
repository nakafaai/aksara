{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalDependencies": ["packages/typescript-config/*.json"],
  "tasks": {
    "//#typecheck:root": {
      "inputs": [
        "tsconfig.json",
        "vitest.config.ts",
        "scripts/**/*.ts",
        "packages/*/scripts/**/*.ts",
        "packages/*/package.json"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["NAKAFA_APP_DIR"],
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["//#typecheck:root", "^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/vitest.config.ts"],
      "outputs": ["coverage/**"]
    },
    "verify:package": {
      "cache": false
    }
  }
}
