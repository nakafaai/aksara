{
  "name": "@nakafa/aksara-compiler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#compiler/*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./incremental": {
      "types": "./dist/incremental.d.ts",
      "import": "./dist/incremental.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf dist",
    "prebuild": "pnpm run clean",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@mdx-js/mdx": "catalog:",
    "@nakafa/aksara-contracts": "workspace:*",
    "effect": "catalog:",
    "eslint-scope": "catalog:",
    "estree-util-visit": "catalog:",
    "mdast-util-to-string": "catalog:",
    "remark-gfm": "catalog:",
    "remark-math": "catalog:",
    "unist-util-visit": "catalog:"
  },
  "devDependencies": {
    "@nakafa/typescript-config": "workspace:*",
    "@types/estree-jsx": "catalog:",
    "@types/mdast": "catalog:",
    "@types/unist": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "mdast-util-mdx": "catalog:",
    "unified": "catalog:",
    "vitest": "catalog:"
  }
}
