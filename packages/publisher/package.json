{
  "name": "@nakafaai/aksara-publisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#publisher/*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "#test/*": "./test/*.ts"
  },
  "exports": {
    "./cleanup": {
      "types": "./dist/cleanup.d.ts",
      "import": "./dist/cleanup.js"
    },
    "./git/source": {
      "types": "./dist/git/source.d.ts",
      "import": "./dist/git/source.js"
    },
    "./material": {
      "types": "./dist/material.d.ts",
      "import": "./dist/material.js"
    },
    "./preparation": {
      "types": "./dist/preparation.d.ts",
      "import": "./dist/preparation.js"
    },
    "./preparation/errors": {
      "types": "./dist/preparation/errors.d.ts",
      "import": "./dist/preparation/errors.js"
    },
    "./publication": {
      "types": "./dist/publication.d.ts",
      "import": "./dist/publication.js"
    },
    "./publication/spec": {
      "types": "./dist/publication/spec.d.ts",
      "import": "./dist/publication/spec.js"
    },
    "./rollback": {
      "types": "./dist/rollback.d.ts",
      "import": "./dist/rollback.js"
    },
    "./rollback/errors": {
      "types": "./dist/rollback/errors.d.ts",
      "import": "./dist/rollback/errors.js"
    },
    "./signing-errors": {
      "types": "./dist/signing-errors.d.ts",
      "import": "./dist/signing-errors.js"
    },
    "./target-errors": {
      "types": "./dist/target-errors.d.ts",
      "import": "./dist/target-errors.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf dist",
    "prebuild": "pnpm run clean",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@nakafaai/aksara-compiler": "workspace:*",
    "@nakafaai/aksara-contracts": "workspace:*",
    "@nakafaai/aksara-corpus": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@nakafaai/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "vitest": "catalog:"
  }
}
