{
  "name": "@nakafa/aksara-utilities",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#utilities/*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    "./http/response": {
      "types": "./dist/http/response.d.ts",
      "import": "./dist/http/response.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf dist coverage",
    "prebuild": "git clean -xdf dist",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@nakafa/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "vitest": "catalog:"
  }
}
