{
  "name": "@nakafa/aksara-corpus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#corpus/*": {
      "types": "./*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    "./articles/registry": {
      "types": "./dist/articles/registry.d.ts",
      "import": "./dist/articles/registry.js"
    },
    "./articles/source": {
      "types": "./dist/articles/source.d.ts",
      "import": "./dist/articles/source.js"
    },
    "./material/registry": {
      "types": "./dist/material/registry.d.ts",
      "import": "./dist/material/registry.js"
    },
    "./material/source": {
      "types": "./dist/material/source.d.ts",
      "import": "./dist/material/source.js"
    },
    "./program/snapshot": {
      "types": "./dist/program/snapshot.d.ts",
      "import": "./dist/program/snapshot.js"
    },
    "./question-bank/registry": {
      "types": "./dist/question-bank/registry.d.ts",
      "import": "./dist/question-bank/registry.js"
    },
    "./question-bank/path": {
      "types": "./dist/question-bank/path.d.ts",
      "import": "./dist/question-bank/path.js"
    },
    "./question-bank/source": {
      "types": "./dist/question-bank/source.d.ts",
      "import": "./dist/question-bank/source.js"
    },
    "./team/source": {
      "types": "./dist/team/source.d.ts",
      "import": "./dist/team/source.js"
    },
    "./tryout/catalog": {
      "types": "./dist/tryout/catalog.d.ts",
      "import": "./dist/tryout/catalog.js"
    },
    "./tryout/projection": {
      "types": "./dist/tryout/projection.d.ts",
      "import": "./dist/tryout/projection.js"
    },
    "./tryout/registry": {
      "types": "./dist/tryout/registry.d.ts",
      "import": "./dist/tryout/registry.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf dist coverage",
    "prebuild": "git clean -xdf dist",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@nakafa/aksara-contracts": "workspace:*",
    "effect": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@nakafa/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "vitest": "catalog:"
  }
}
