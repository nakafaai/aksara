{
  "name": "aksara",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "imports": {
    "#scripts/*": "./scripts/*.ts"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "accept": "turbo run accept --filter=@nakafa/aksara-cli",
    "abort": "turbo run abort --filter=@nakafa/aksara-cli",
    "boundaries": "node scripts/check-imports.ts",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "format": "ultracite fix",
    "jsdocs": "node scripts/check-docs.ts",
    "lint": "ultracite check",
    "lines": "node scripts/check-lines.ts",
    "names": "node scripts/check-paths.ts",
    "test": "turbo run test",
    "test:root": "vitest run --config vitest.config.ts",
    "typecheck:root": "tsc --project tsconfig.json",
    "typecheck": "turbo run typecheck",
    "verify:package": "turbo run verify:package",
    "workflows": "node scripts/check-workflows.ts",
    "changeset": "changeset",
    "cleanup": "turbo run cleanup --filter=@nakafa/aksara-cli",
    "dev": "turbo run dev --filter=@nakafa/aksara-cli",
    "release": "turbo run release --filter=@nakafa/aksara-cli",
    "recover": "turbo run recover --filter=@nakafa/aksara-cli",
    "rollback": "turbo run rollback --filter=@nakafa/aksara-cli",
    "status": "turbo run status --filter=@nakafa/aksara-cli",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@effect/language-service": "0.87.0",
    "@types/node": "24.13.3",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-istanbul": "catalog:",
    "effect": "catalog:",
    "turbo": "2.10.6",
    "typescript": "catalog:",
    "ultracite": "7.9.4",
    "vitest": "catalog:"
  }
}
